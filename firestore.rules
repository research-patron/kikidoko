rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /feature_requests/{requestId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly([
          'message_raw',
          'created_at',
          'client_fingerprint',
          'status'
        ]) &&
        request.resource.data.message_raw is string &&
        request.resource.data.created_at is timestamp &&
        request.resource.data.client_fingerprint is string &&
        request.resource.data.status == 'new' &&
        request.resource.data.message_raw.size() >= 8 &&
        request.resource.data.message_raw.size() <= 500 &&
        request.resource.data.client_fingerprint.size() >= 6 &&
        request.resource.data.client_fingerprint.size() <= 120;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
